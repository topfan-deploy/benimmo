generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  CLIENT
  AGENT
  ADMIN
}

enum PriceType {
  DAILY
  MONTHLY
  YEARLY
}

enum PropertyType {
  APARTMENT
  HOUSE
  STUDIO
  VILLA
}

enum PropertyStatus {
  PENDING_REVIEW
  ACTIVE
  REJECTED
  RENTED
}

enum ImageVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentMethod {
  MOMO
  MOOV
  CARD
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum DocumentType {
  IDENTITY
  OWNERSHIP
  TAX_RECEIPT
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum HandoverStatus {
  PENDING
  CONFIRMED
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  phone            String?
  password         String
  name             String
  role             UserRole  @default(CLIENT)
  isVerified       Boolean   @default(false)
  identityDocument String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  properties       Property[]
  subscriptions    Subscription[]
  wallet           Wallet?
  withdrawals      Withdrawal[]
  sentMessages     Message[]       @relation("SentMessages")
  receivedMessages Message[]       @relation("ReceivedMessages")
  bookings         Booking[]       @relation("ClientBookings")
  appointments     Appointment[]   @relation("ClientAppointments")
  agentAppointments Appointment[]  @relation("AgentAppointments")
  agentAvailability AgentAvailability[]
  documents        Document[]
  reviewedDocuments Document[]     @relation("ReviewedDocuments")
  favorites        Favorite[]
  reviews          Review[]
  confirmedHandovers KeyHandover[] @relation("ConfirmedHandovers")
}

model Property {
  id                String         @id @default(cuid())
  title             String
  description       String
  address           String
  city              String
  price             Float
  priceType         PriceType
  bedrooms          Int
  bathrooms         Int
  area              Float?
  propertyType      PropertyType
  status            PropertyStatus @default(PENDING_REVIEW)
  ownershipDocument String?
  latitude          Float?
  longitude         Float?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  ownerId           String
  owner             User           @relation(fields: [ownerId], references: [id])
  images            PropertyImage[]
  appointments      Appointment[]
  bookings          Booking[]
  favorites         Favorite[]
  reviews           Review[]
  messages          Message[]
}

model PropertyImage {
  id                 String                   @id @default(cuid())
  url                String
  isVerified         Boolean                  @default(false)
  exifData           Json?
  imageHash          String?
  verificationStatus ImageVerificationStatus  @default(PENDING)
  rejectionReason    String?
  createdAt          DateTime                 @default(now())

  propertyId         String
  property           Property                 @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Appointment {
  id             String            @id @default(cuid())
  requestedDate  DateTime
  confirmedDate  DateTime?
  status         AppointmentStatus @default(PENDING)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  propertyId     String
  property       Property          @relation(fields: [propertyId], references: [id])
  clientId       String
  client         User              @relation("ClientAppointments", fields: [clientId], references: [id])
  agentId        String?
  agent          User?             @relation("AgentAppointments", fields: [agentId], references: [id])
}

model AgentAvailability {
  id        String   @id @default(cuid())
  date      DateTime
  startTime String
  endTime   String
  isBooked  Boolean  @default(false)

  agentId   String
  agent     User     @relation(fields: [agentId], references: [id])
}

model Payment {
  id                   String        @id @default(cuid())
  amount               Float
  commission           Float         @default(0)
  ownerAmount          Float         @default(0)
  currency             String        @default("XOF")
  method               PaymentMethod
  transactionRef       String?
  status               PaymentStatus @default(PENDING)
  fedapayTransactionId String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  bookingId            String        @unique
  booking              Booking       @relation(fields: [bookingId], references: [id])
}

model Booking {
  id          String        @id @default(cuid())
  startDate   DateTime
  endDate     DateTime
  totalAmount Float
  status      BookingStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  propertyId  String
  property    Property      @relation(fields: [propertyId], references: [id])
  clientId    String
  client      User          @relation("ClientBookings", fields: [clientId], references: [id])
  payment     Payment?
  keyHandover KeyHandover?
}

model KeyHandover {
  id               String         @id @default(cuid())
  confirmationCode String         @unique
  status           HandoverStatus @default(PENDING)
  confirmedAt      DateTime?
  createdAt        DateTime       @default(now())

  bookingId        String         @unique
  booking          Booking        @relation(fields: [bookingId], references: [id])
  confirmedById    String?
  confirmedBy      User?          @relation("ConfirmedHandovers", fields: [confirmedById], references: [id])
}

model Document {
  id                      String         @id @default(cuid())
  type                    DocumentType
  url                     String
  status                  DocumentStatus @default(PENDING)
  reviewNote              String?
  smileJobId              String?
  smileResult             Json?
  smileVerificationStatus String?
  idType                  String?
  idNumber                String?
  autoVerifiedAt          DateTime?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  userId     String
  user       User           @relation(fields: [userId], references: [id])
  reviewedById String?
  reviewedBy   User?        @relation("ReviewedDocuments", fields: [reviewedById], references: [id])
}

model Favorite {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  @@unique([userId, propertyId])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  @@unique([userId, propertyId])
}

model Subscription {
  id                   String             @id @default(cuid())
  amount               Float              @default(10000)
  currency             String             @default("XOF")
  status               SubscriptionStatus @default(ACTIVE)
  startDate            DateTime           @default(now())
  endDate              DateTime
  method               PaymentMethod?
  fedapayTransactionId String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  userId               String
  user                 User               @relation(fields: [userId], references: [id])
}

model Wallet {
  id           String              @id @default(cuid())
  balance      Float               @default(0)
  currency     String              @default("XOF")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  userId       String              @unique
  user         User                @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String   @id @default(cuid())
  amount      Float
  type        String   // CREDIT (paiement reçu) ou DEBIT (retrait)
  description String
  reference   String?  // lien vers paymentId ou withdrawalId
  createdAt   DateTime @default(now())

  walletId    String
  wallet      Wallet   @relation(fields: [walletId], references: [id])
}

model Withdrawal {
  id           String           @id @default(cuid())
  amount       Float
  currency     String           @default("XOF")
  method       PaymentMethod    // MOMO ou MOOV
  phoneNumber  String
  status       WithdrawalStatus @default(PENDING)
  processedAt  DateTime?
  adminNote    String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  userId       String
  user         User             @relation(fields: [userId], references: [id])
}

model Message {
  id         String   @id @default(cuid())
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id])
}
